{
  "name": "@beyond.dev/objects",
  "version": "0.1.0",
  "description": "S3-compatible object storage SDK for the Beyond platform.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beyondoss/objects.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./react": {
      "import": "./dist/react/index.mjs",
      "types": "./dist/react/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "generate-types": "node scripts/generate-types.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "std-env": "^3.9.0"
  },
  "peerDependencies": {
    "jotai": "^2.0.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "jotai": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@peculiar/x509": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "jotai": "^2.0.0",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.6.1",
    "react": "^18.0.0",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
